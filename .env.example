# MBA-Vault environment variables (EXAMPLE — copy to .env and fill in; .env is git-ignored).
# Nothing real goes in this file. The real .env is never committed (public repo).

# --- Gemini (server-side only; never exposed to the browser) ---
# Used by /ask (answers) and the local ingestion pipeline (embeddings).
GEMINI_API_KEY=

# --- Auth (Phase 3) ---
# Generate all four values locally with:  npm run provision:auth
# (prints an argon2id hash + a TOTP secret/QR + a session secret to paste here).
# These are read from the process environment at runtime — never commit real values.
#
# Secret that seals the iron-session cookie (>= 32 chars; base64url from the CLI).
SESSION_SECRET=
# The single user's login name.
AUTH_USERNAME=
# Argon2id PHC hash of the password. Contains '$' — paste it verbatim into the
# env FILE; do not wrap it in quotes and do not `export` it from a shell.
AUTH_PASSWORD_HASH=
# Base32 TOTP secret for the authenticator app (2FA).
TOTP_SECRET=
